<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="OptishotV1DOTNET.UI.Components.ModeSelector">
    <Frame
        BackgroundColor="#99000000"
        CornerRadius="24"
        Padding="6"
        HasShadow="False">
        <HorizontalStackLayout Spacing="4">

            <!-- Lighting toggle -->
            <Border
                x:Name="LightingFrame"
                Padding="14,8"
                StrokeThickness="0">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="18" />
                </Border.StrokeShape>
                <Border.GestureRecognizers>
                    <TapGestureRecognizer
                        Command="{Binding ToggleLightingCommand, Source={RelativeSource AncestorType={x:Type ContentView}}}" />
                </Border.GestureRecognizers>
                <HorizontalStackLayout Spacing="6" InputTransparent="True">
                    <Label
                        x:Name="LightingIcon"
                        Text="☀"
                        FontSize="15"
                        VerticalOptions="Center" />
                    <Label
                        x:Name="LightingLabel"
                        Text="Light"
                        FontSize="14"
                        FontAttributes="Bold"
                        VerticalOptions="Center" />
                </HorizontalStackLayout>
            </Border>

            <!-- Composition toggle -->
            <Border
                x:Name="CompositionFrame"
                Padding="14,8"
                StrokeThickness="0">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="18" />
                </Border.StrokeShape>
                <Border.GestureRecognizers>
                    <TapGestureRecognizer
                        Command="{Binding ToggleCompositionCommand, Source={RelativeSource AncestorType={x:Type ContentView}}}" />
                </Border.GestureRecognizers>
                <HorizontalStackLayout Spacing="6" InputTransparent="True">
                    <Label
                        x:Name="CompositionIcon"
                        Text="✦"
                        FontSize="15"
                        VerticalOptions="Center" />
                    <Label
                        x:Name="CompositionLabel"
                        Text="Clean"
                        FontSize="14"
                        FontAttributes="Bold"
                        VerticalOptions="Center" />
                </HorizontalStackLayout>
            </Border>

        </HorizontalStackLayout>
    </Frame>
</ContentView>
