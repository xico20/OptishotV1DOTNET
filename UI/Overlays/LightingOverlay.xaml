<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="OptishotV1DOTNET.UI.Overlays.LightingOverlay">
    <Frame
        x:Name="BadgeFrame"
        CornerRadius="20"
        Padding="12,6"
        HasShadow="False"
        BackgroundColor="#CC1C1C1E">
        <HorizontalStackLayout Spacing="6">
            <Label
                x:Name="StatusIcon"
                Text="☀"
                FontSize="14"
                TextColor="{Binding StatusColor, Source={RelativeSource AncestorType={x:Type ContentView}}}"
                VerticalOptions="Center" />
            <Label
                x:Name="StatusLabel"
                Text="{Binding LabelText, Source={RelativeSource AncestorType={x:Type ContentView}}}"
                FontSize="13"
                FontAttributes="Bold"
                TextColor="White"
                VerticalOptions="Center" />
        </HorizontalStackLayout>
    </Frame>
</ContentView>
