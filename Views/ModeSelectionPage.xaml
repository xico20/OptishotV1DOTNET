<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:OptishotV1DOTNET.ViewModels"
             x:Class="OptishotV1DOTNET.Views.ModeSelectionPage"
             BackgroundColor="Black"
             Shell.NavBarIsVisible="False"
             NavigationPage.HasNavigationBar="False">

    <Grid RowDefinitions="Auto,*">

        <!-- Title -->
        <Label
            Grid.Row="0"
            Text="OptiShot"
            FontSize="34"
            FontAttributes="Bold"
            TextColor="White"
            HorizontalOptions="Center"
            Margin="0,60,0,40" />

        <!-- Mode buttons -->
        <VerticalStackLayout
            Grid.Row="1"
            Spacing="16"
            Padding="32,0"
            VerticalOptions="Start">

            <BindableLayout.ItemsSource>
                <Binding Path="Modes" />
            </BindableLayout.ItemsSource>
            <BindableLayout.ItemTemplate>
                <DataTemplate x:DataType="vm:ModeItem">
                    <Frame
                        BackgroundColor="#1AFFFFFF"
                        BorderColor="#33FFFFFF"
                        CornerRadius="16"
                        Padding="20,18"
                        HasShadow="False">
                        <Frame.GestureRecognizers>
                            <TapGestureRecognizer
                                Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.SelectModeCommand}"
                                CommandParameter="{Binding Mode}" />
                        </Frame.GestureRecognizers>
                        <Grid ColumnDefinitions="Auto,*,Auto">
                            <Label
                                Grid.Column="0"
                                Text="{Binding Icon}"
                                FontSize="22"
                                TextColor="White"
                                VerticalOptions="Center"
                                Margin="0,0,14,0" />
                            <Label
                                Grid.Column="1"
                                Text="{Binding Name}"
                                FontSize="18"
                                FontAttributes="Semibold"
                                TextColor="White"
                                VerticalOptions="Center" />
                            <Label
                                Grid.Column="2"
                                Text="›"
                                FontSize="22"
                                TextColor="#88FFFFFF"
                                VerticalOptions="Center" />
                        </Grid>
                    </Frame>
                </DataTemplate>
            </BindableLayout.ItemTemplate>

        </VerticalStackLayout>

    </Grid>
</ContentPage>
